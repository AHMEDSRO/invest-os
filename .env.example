# ============================================
# Invest-OS — متغيرات البيئة
# انسخ الملف ده إلى .env.local واملأ القيم
# ممنوع رفع .env.local على GitHub (متجاهَل تلقائيًا)
# ============================================

# من Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# مزوّد الشات بوت: gemini (افتراضي) | groq | openrouter
LLM_PROVIDER=gemini

# مفتاح Gemini المجاني من https://aistudio.google.com
GEMINI_API_KEY=
# الموديل (اختياري) — الافتراضي gemini-flash-latest لأن 2.0 اتقاعد من الـ free tier
# GEMINI_MODEL=gemini-flash-latest

# (اختياري) لو غيّرت LLM_PROVIDER
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
